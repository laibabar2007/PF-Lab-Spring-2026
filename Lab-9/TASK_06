#include <stdio.h> 
float totalRevenue(float bills[],int n){ 
float sum=0; 
for(int i=0;i<n;i++) 
{ sum+=bills[i]; } 
return sum; } 
int bestTable(float bills[],int n){ 
int maxIdx=0; 
for(int i=1;i<n;i++){ 
if(bills[i]>bills[maxIdx]){ 
maxIdx=i; } } 
return maxIdx; } 
int isProfitable(float total){ 
if(total>10000){ 
return 1; } 
return 0; } 
int main(){ 
float bills[5]; 
for(int i=0;i<5;i++){ 
printf("Enter bill for Table %d: ",i+1); 
scanf("%f",&bills[i]); } 
float total=totalRevenue(bills,5); 
int best=bestTable(bills,5); 
printf("Total Revenue: %.2f\n",total); 
printf("Best Table: Table %d\n",best+1);
if(isProfitable(total)){ 
printf("Profitable\n"); } 
else{ 
printf("Not Profitable\n"); } 
return 0; 
} 
