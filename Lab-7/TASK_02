#include <stdio.h>
int main(){
int a[10],i,num,count=0;
printf("Enter 10 numbers:\n");
for(i=0;i<10;i++)
{ scanf("%d",&a[i]); }
printf("Enter the number to search: ");
scanf("%d",&num);
for(i=0;i<10;i++)
{ if(a[i]==num)
{ count++; } }
if(count>0)
{ printf("The number %d occurred %d times",num ,count); }
else
{ printf("The number you entered wasn't found"); }
return 0;
}
