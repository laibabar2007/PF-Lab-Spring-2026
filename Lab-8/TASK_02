#include <stdio.h>
int main(){
int seats[5][6],i,j,count=0,max=0,row=0,booked;
printf("Enter seat status (0 for available and 1 to represent booked):\n");
for(i=0;i<5;i++)
{ for(j=0;j<6;j++)
{scanf("%d",&seats[i][j]);}}
for(i=0;i<5;i++)
{booked=0;
for(j=0;j<6;j++)
{ if(seats[i][j]==0)
{ count=count+1; }
if(seats[i][j]==1)
{ booked=booked+1;} }
if(booked>max)
{ max=booked;
row=i; }}
printf("The number of available seats= %d\n",count);
printf("The number of row with maximum booked seats = %d\n",row+1);
return 0; }
