#include <stdio.h>
int main(){
    FILE *fptr;
    int score, val;
    int i;
    int sum = 0;
    float avg;
    fptr = fopen("survey.txt", "w");
    if(fptr == NULL){
        printf("Error opening file\n");
        return 0;
    }
    printf("Enter 5 survey scores (1-10):\n");
    for(i = 0; i < 5; i++){
        scanf("%d", &score);
        fprintf(fptr, "%d\n", score);
    }
    fclose(fptr);
    fptr = fopen("survey.txt", "r");
    if(fptr == NULL){
        printf("Error opening file\n");
        return 0;
    }
    while(fscanf(fptr, "%d", &val) == 1){
        sum = sum + val;
    }
    fclose(fptr);
    avg = sum / 5.0;
    printf("Sum = %d\n", sum);
    printf("Average = %.2f\n", avg);
    return 0;
}
