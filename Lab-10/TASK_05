#include <stdio.h>
#include <string.h>
int main(){
char words[6][20];
int seen[6]={0};
int i,j,k,count;
printf("Enter 6 words:\n");
for(i=0;i<6;i++){
scanf("%s",words[i]); }
for(i=0;i<6;i++){
if(seen[i]==0){
count=0;
for(j=0;j<6;j++){
if(strcmp(words[i],words[j])==0){
count++;
seen[j]=1; } }
printf("Word: %s\n",words[i]);
printf("Frequency: %d\n",count);
printf("Characters: ");
for(k=0;words[i][k]!='\0';k++){
printf("%c",words[i][k]); }
printf("\n"); } }
return 0; }
