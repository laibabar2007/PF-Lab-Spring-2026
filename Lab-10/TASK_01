#include <stdio.h>
#include <string.h>
#include <ctype.h>
int main()
{
    char name[50];
    int i,valid=1;
    printf("Enter name: ");
    scanf("%[^\n]", name);
    if(strlen(name)<3 || strlen(name)>20)
        valid=0;
    if(name[0]==' ' || name[strlen(name)-1]==' ')
        valid=0;
    for(i=0;i<strlen(name);i++)
    { if(isdigit(name[i]))
            valid=0; }
    if(valid)
        printf("Valid name!\nLength: %d", strlen(name));
    else
        printf("Invalid name!\nLength: %d", strlen(name));
    return 0;
}
