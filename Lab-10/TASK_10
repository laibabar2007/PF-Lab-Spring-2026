#include <stdio.h>
int main(){
    FILE *fptr;
    char name[50];
    int s1, s2, s3;
    float avg;
    int pass;
    char line[100];
    printf("Enter student name: ");
    scanf("%s", name);
    printf("Enter 3 subject scores: ");
    scanf("%d %d %d", &s1, &s2, &s3);
    avg = (s1 + s2 + s3) / 3.0;
    if(avg >= 50)
        pass=1;
    else
        pass=0;
    fptr = fopen("report.txt", "w+");
    if(fptr == NULL){
        printf("Error opening file\n");
        return 0; }
    fprintf(fptr, "Student Name: %s\n", name);
    fprintf(fptr, "Subject 1: %d\n", s1);
    fprintf(fptr, "Subject 2: %d\n", s2);
    fprintf(fptr, "Subject 3: %d\n", s3);
    fprintf(fptr, "Average: %.2f\n", avg);
    if(pass == 1)
        fprintf(fptr, "Status: Pass\n");
    else
        fprintf(fptr, "Status: Fail\n");
    rewind(fptr);
    while(fgets(line, sizeof(line), fptr) != NULL){
        printf("%s", line);
    }
    fclose(fptr);
    return 0;
}
