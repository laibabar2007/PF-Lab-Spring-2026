#include <stdio.h>
#include <stdlib.h>
int main() {
    int students,i;
    float *grades;
    printf("Enter the number of students: ");
    scanf("%d",&students);
    grades = (float*)malloc(students*sizeof(float));
    if (grades == NULL) {
        printf("Memory allocation has been failed to assign.");
        return 1; }
    for(i=0;i<students;i++) {
      printf("Enter grade of student %d: ",i+1);
      scanf("%f",&grades[i]); }
    printf("\nStudent Grades are:\n");
    for(i=0;i<students;i++) 
    {  printf("Student %d =%.2f\n",i+1,grades[i]); }
    free(grades);
    return 0;
}
